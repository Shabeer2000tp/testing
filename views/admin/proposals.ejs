<%- include('../partials/_messages') %>

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><%= title %></h1>
    </div>

    <!-- Pending Proposals Section -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Pending Admin Confirmation</h6>
        </div>
        <div class="card-body">
            <% if (pendingProposals.length > 0) { %>
                <div class="accordion" id="pendingProposalsAccordion">
                    <% pendingProposals.forEach((proposal, index) => { %>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading<%= index %>">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
                                    <strong><%= proposal.title %></strong>&nbsp;-&nbsp;<span class="text-muted">Team: <%= proposal.team.name %></span>
                                </button>
                            </h2>
                            <div id="collapse<%= index %>" class="accordion-collapse collapse" data-bs-parent="#pendingProposalsAccordion">
                                <div class="accordion-body">
                                    <p><strong>Domain:</strong> <%= proposal.domain.name %></p>
                                    <p><strong>Description:</strong> <%= proposal.description %></p>
                                    <hr>
                                    <p><strong>Guide:</strong> <%= proposal.team.guide.name %></p>
                                    <p><strong>Guide's Feedback:</strong> <em class="text-muted"><%= proposal.guideFeedback || 'No feedback provided.' %></em></p>
                                    <hr>
                                    <div class="d-flex justify-content-end gap-2">
                                        <!-- Reject Button/Modal -->
                                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal<%= proposal._id %>">
                                            Reject
                                        </button>
                                        <!-- Approve Form -->
                                        <form action="/admin/proposals/<%= proposal._id %>/approve" method="POST">
                                            <button type="submit" class="btn btn-success">Approve</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Reject Modal -->
                        <div class="modal fade" id="rejectModal<%= proposal._id %>" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form action="/admin/proposals/<%= proposal._id %>/reject" method="POST">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Reject Proposal: <%= proposal.title %></h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label for="feedback<%= proposal._id %>" class="form-label">Reason for Rejection (Required)</label>
                                                <textarea class="form-control" id="feedback<%= proposal._id %>" name="feedback" rows="3" required></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-center text-muted">No proposals are currently pending your review.</p>
            <% } %>
        </div>
    </div>

    <!-- Approved Projects Section -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-success">Approved Projects</h6>
        </div>
        <div class="card-body">
            <% if (approvedProposals.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Project Title</th>
                                <th>Team</th>
                                <th>Guide</th>
                                <th>Domain</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% approvedProposals.forEach(proposal => { %>
                                <tr>
                                    <td><%= proposal.title %></td>
                                    <td><a href="/admin/teams/<%= proposal.team._id %>"><%= proposal.team.name %></a></td>
                                    <td><%= proposal.team.guide.name %></td>
                                    <td><span class="badge bg-secondary"><%= proposal.domain.name %></span></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p class="text-center text-muted">No projects have been approved yet.</p>
            <% } %>
        </div>
    </div>

</div>