<%- include('../partials/_messages') %>

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><%= title %></h1>
        <% if (activeSprint) { %>
            <a href="/student/tasks/new" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Add New Task
            </a>
        <% } %>
    </div>

    <% if (activeSprint) { %>
        <div class="row">
            <!-- Left Column: Backlog Items -->
            <div class="col-lg-6">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Project Backlog (New Items)</h6>
                    </div>
                    <div class="card-body">
                        <% const newItems = backlogItems.filter(item => item.status === 'New'); %>
                        <% if (newItems.length > 0) { %>
                            <div class="list-group">
                                <% newItems.forEach(item => { %>
                                    <% if (item.status === 'New') { %>
                                        <div class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <span class="badge bg-<%= item.priority === 'High' ? 'danger' : (item.priority === 'Medium' ? 'warning' : 'info') %> me-2"><%= item.priority %></span>
                                                <%= item.description %>
                                            </div>
                                            <a href="/student/backlog/<%= item._id %>/plan" class="btn btn-sm btn-outline-success">Plan Task</a>
                                        </div>
                                    <% } %>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="text-center text-muted">There are no new items in the project backlog.</p>
                        <% } %>
                    </div>
                </div>

                <!-- NEW: Planned Backlog Items -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-secondary">Planned Items</h6>
                    </div>
                    <div class="card-body">
                        <% const plannedItems = backlogItems.filter(item => item.status === 'In Sprint'); %>
                        <% if (plannedItems.length > 0) { %>
                            <div class="list-group">
                                <% plannedItems.forEach(item => { %>
                                    <div class="list-group-item list-group-item-light text-muted">
                                        <i class="fas fa-check-circle text-success me-2"></i><%= item.description %>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="text-center text-muted">No backlog items have been moved to the sprint yet.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Right Column: Sprint Tasks -->
            <div class="col-lg-6">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-success">Tasks in Current Sprint (<%= activeSprint.name %>)</h6>
                    </div>
                    <div class="card-body">
                        <% if (sprintTasks.length > 0) { %>
                            <ul class="list-group">
                                <% 
                                const groupedTasks = [];
                                const processed = new Set();
                                sprintTasks.forEach(task => {
                                    if (processed.has(task.description)) return;
                                    if (task.assignedToAll) processed.add(task.description);
                                    groupedTasks.push(task);
                                });
                                %>
                                <% groupedTasks.forEach(task => { %>
                                    <li class="list-group-item d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="mb-1"><%= task.description %></p>
                                            <small class="d-block text-muted">
                                                <i class="fas fa-user me-1"></i> <%= task.assignedToAll ? 'All Members' : (task.assignedTo ? task.assignedTo.name : 'Unassigned') %>
                                            </small>
                                            <small class="d-block text-muted">
                                                <i class="fas fa-calendar-alt me-1"></i> <%= new Date(task.startDate).toLocaleDateString() %> - <%= new Date(task.endDate).toLocaleDateString() %>
                                            </small>
                                        </small>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
                            <p class="text-center text-muted">No tasks have been planned for this sprint yet.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="card text-center p-5">
            <div class="card-body">
                <h5 class="card-title">No Active Sprint</h5>
                <p class="card-text text-muted">There is no active sprint to plan for. Please wait for an admin or guide to create one.</p>
            </div>
        </div>
    <% } %>
</div>