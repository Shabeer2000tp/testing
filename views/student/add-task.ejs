<%- include('../partials/_messages') %>

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><%= title %></h1>
        <a href="/student/dashboard" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    <div class="row">
        <!-- Left Column: Form -->
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">New Task Details</h6>
                </div>
                <div class="card-body">
                    <form action="/student/tasks" method="POST">
                        <!-- Hidden fields for IDs -->
                        <input type="hidden" name="sprintId" value="<%= activeSprint._id %>">
                        <input type="hidden" name="teamId" value="<%= team._id %>">

                        <!-- Backlog Item (Optional) -->
                        <div class="mb-3">
                            <label for="backlogItemId" class="form-label">Link to Backlog Item (Optional)</label>
                            <select class="form-select" id="backlogItemId" name="backlogItemId">
                                <option value="">-- Create as new ad-hoc task --</option>
                                <% backlogItems.forEach(item => { %>
                                    <option value="<%= item._id %>">[<%= item.priority %>] <%= item.description %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Task Description -->
                        <div class="mb-3">
                            <label for="description" class="form-label">Task Description</label>
                            <textarea class="form-control" id="description" name="description" rows="3" required placeholder="Enter a detailed description of the task..."></textarea>
                            <small class="form-text text-muted">If linking to a backlog item, this can be a sub-task description.</small>
                        </div>

                        <!-- Story Points -->
                        <div class="mb-3">
                            <label for="storyPoints" class="form-label">Story Points</label>
                            <input type="number" class="form-control" id="storyPoints" name="storyPoints" min="1" required>
                        </div>

                        <!-- Start & End Dates -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label">Start Date</label>
                                <input type="date" class="form-control" id="startDate" name="startDate" required>
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label">End Date</label>
                                <input type="date" class="form-control" id="endDate" name="endDate" required>
                            </div>
                        </div>

                        <!-- Assignment Options -->
                        <div class="mb-4">
                            <label class="form-label">Assign To</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="assignToAll" id="assignToMe" value="false" checked>
                                <label class="form-check-label" for="assignToMe">
                                    Just Me (<%= user.name %>)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="assignToAll" id="assignToAll" value="true">
                                <label class="form-check-label" for="assignToAll">
                                    All Team Members
                                </label>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-plus-circle me-2"></i>Add Task to Sprint
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Sprint Info -->
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-secondary">Target Sprint</h6>
                </div>
                <div class="card-body">
                    <h5 class="card-title"><%= activeSprint.name %></h5>
                    <p class="card-text text-muted">
                        <%= new Date(activeSprint.startDate).toLocaleDateString() %> - <%= new Date(activeSprint.endDate).toLocaleDateString() %>
                    </p>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span>Sprint Capacity:</span>
                        <strong><%= activeSprint.capacity %> SP</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Current Load:</span>
                        <strong><%= activeSprint.currentLoad || 0 %> SP</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>