<%- include('../partials/_messages') %>

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><%= title %></h1>
    </div>

    <% if (pastSprints && pastSprints.length > 0) { %>
        <div class="accordion" id="pastSprintsAccordion">
            <% pastSprints.forEach((sprint, index) => { %>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading-<%= sprint._id %>">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= sprint._id %>">
                            <div class="d-flex justify-content-between w-100 me-3">
                                <span><strong><%= sprint.name %></strong></span>
                                <span class="text-muted"><%= new Date(sprint.startDate).toLocaleDateString() %> - <%= new Date(sprint.endDate).toLocaleDateString() %></span>
                            </div>
                        </button>
                    </h2>
                    <div id="collapse-<%= sprint._id %>" class="accordion-collapse collapse" data-bs-parent="#pastSprintsAccordion">
                        <div class="accordion-body">
                            <% if (sprint.burndownChartData) { %>
                                <div class="mb-4" style="height: 300px;">
                                    <canvas id="burndownChart-<%= sprint._id %>"></canvas>
                                </div>
                            <% } else { %>
                                <p class="text-center text-muted">No task data available for this sprint.</p>
                            <% } %>

                            <h6 class="mt-4">Tasks in this Sprint:</h6>
                            <% if (sprint.tasks && sprint.tasks.length > 0) { %>
                                <ul class="list-group">
                                    <% sprint.tasks.forEach(task => { %>
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <span class="badge bg-<%= task.status === 'Done' ? 'success' : 'secondary' %> me-2"><%= task.status %></span>
                                                <%= task.description %>
                                                <% if (task.isMoved) { %>
                                                    <small class="text-info">(Moved from a previous sprint)</small>
                                                <% } %>
                                            </div>
                                            <% if (task.status !== 'Done') { %>
                                                <form action="/student/tasks/<%= task._id %>/move" method="POST">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Move to Current Sprint</button>
                                                </form>
                                            <% } %>
                                        </li>
                                    <% }) %>
                                </ul>
                            <% } else { %>
                                <p class="text-muted">No tasks were recorded for this sprint.</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="card text-center p-5">
            <p class="text-muted mb-0">You have no completed sprints to display.</p>
        </div>
    <% } %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    <% pastSprints.forEach(sprint => { %>
        <% if (sprint.burndownChartData) { %>
            const ctx_<%= sprint._id %> = document.getElementById('burndownChart-<%= sprint._id %>').getContext('2d');
            const segmentColors_<%= sprint._id %> = <%- sprint.burndownChartData.segmentColors %>;

            new Chart(ctx_<%= sprint._id %>, {
                type: 'line',
                data: {
                    labels: <%- sprint.burndownChartData.labels %>,
                    datasets: [{
                        label: 'Remaining Work',
                        data: <%- sprint.burndownChartData.actualData %>,
                        fill: false,
                        tension: 0.1,
                        segment: {
                            // This function sets the border color for each line segment.
                            // It uses the color from the segmentColors array based on the starting point's index.
                            borderColor: ctx => segmentColors_<%= sprint._id %>[ctx.p0DataIndex] || '#4e73df'
                        }
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: { display: true, text: 'Story Points' }
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        <% } %>
    <% }) %>
});
</script>