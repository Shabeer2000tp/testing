<%- include('../partials/_messages') %>
<div class="container-fluid">

    <!-- Page Heading & Quick Actions -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Welcome, <%= user.name.split(' ')[0] %>!</h1>
        <div>
            <a href="/student/daily-log" class="btn btn-sm btn-outline-primary shadow-sm"><i class="fas fa-clipboard-list fa-sm me-2"></i> Daily Log</a>
            <a href="/student/upload" class="btn btn-sm btn-outline-success shadow-sm"><i class="fas fa-upload fa-sm me-2"></i> Upload Deliverable</a>
            <a href="/student/backlog" class="btn btn-sm btn-outline-secondary shadow-sm"><i class="fas fa-list-ul fa-sm me-2"></i> View Backlog</a>
        </div>
    </div>

    <% if (team) { %>
        <!-- Stat Cards Row -->
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card stat-card h-100" style="border-left-color: var(--accent);">
                    <div class="card-body">
                        <div class="stat-card-title">Active Sprint</div>
                        <div class="stat-card-value fs-5"><%= activeSprint ? activeSprint.name : 'None' %></div>
                        <i class="fas fa-sync-alt stat-card-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card stat-card h-100" style="border-left-color: #28a745;">
                    <div class="card-body">
                        <div class="stat-card-title">Sprint Progress</div>
                        <div class="stat-card-value"><%= activeSprint ? `${team.completedStoryPoints} / ${team.sprintCapacity}` : 'N/A' %> <span class="fs-6 text-muted">SP</span></div>
                        <i class="fas fa-check-circle stat-card-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card stat-card h-100" style="border-left-color: #f6c23e;">
                    <div class="card-body">
                        <div class="stat-card-title">Overall Progress</div>
                        <div class="stat-card-value"><%= team.overallCompletedPoints %> / <%= team.overallTotalPoints || 'N/A' %> <span class="fs-6 text-muted">SP</span></div>
                        <i class="fas fa-tasks stat-card-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card stat-card h-100" style="border-left-color: #1cc88a;">
                    <div class="card-body">
                        <div class="stat-card-title">Upcoming Review</div>
                        <div class="stat-card-value fs-5"><%= upcomingReviews && upcomingReviews.length > 0 ? new Date(upcomingReviews[0].reviewDate).toLocaleDateString() : 'None' %></div>
                        <i class="fas fa-calendar-check stat-card-icon"></i>
                    </div>
                </div>
            </div>
        </div>

        <% if (activeSprint) { %>
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-info-circle me-2"></i>Active Sprint Details</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Sprint Name:</strong> <%= activeSprint.name %><br>
                            <strong>Goal:</strong> <%= activeSprint.goal %><br>
                        </div>
                        <div class="col-md-6">
                            <strong>Start Date:</strong> <%= new Date(activeSprint.startDate).toLocaleDateString() %><br>
                            <strong>End Date:</strong> <%= new Date(activeSprint.endDate).toLocaleDateString() %><br>
                            <strong>Capacity:</strong> <%= activeSprint.capacity %> Story Points
                        </div>
                    </div>
                </div>
            </div>
        <% } %>


        <!-- Main Content Row -->
        <div class="row">

            <!-- Left Column -->
            <div class="col-lg-8">
                <!-- Sprint Burndown Chart -->
                <% if (activeSprint && burndownChartData) { %>
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-line me-2"></i>Active Sprint Burndown</h6>
                        </div>
                        <div class="card-body">
                            <div style="height: 300px;">
                                <canvas id="sprintBurndownChart"></canvas>
                            </div>
                        </div>
                    </div>
                <% } %>

                <!-- Overall Project Burndown Chart -->
                <% if (team.overallBurndownChartData) { %>
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-chart-area me-2"></i>Overall Project Burndown</h6>
                        </div>
                        <div class="card-body">
                            <div style="height: 300px;">
                                <canvas id="overallBurndownChart"></canvas>
                            </div>
                        </div>
                    </div>
                <% } %>

                <!-- My Tasks Table -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-user-check me-2"></i>My Tasks in Active Sprint</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Task Description</th>
                                        <th>Story Points</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% const myTasks = teamTasks.filter(t => t.assignedTo && t.assignedTo._id.equals(user.profileId) || t.assignedToAll); %>
                                    <% if (myTasks.length > 0) { %>
                                        <% myTasks.forEach(task => { %>
                                            <tr>
                                                <td><%= task.description %></td>
                                                <td><span class="badge bg-secondary"><%= task.storyPoints %></span></td>
                                                <td><span class="status-badge <%= task.realtimeStatus.badgeClass %>"><%= task.realtimeStatus.text %></span></td>
                                                <td>
                                                    <form action="/student/tasks/<%= task._id %>/status" method="POST" class="d-inline">
                                                        <% if (task.status === 'To-Do') { %>
                                                            <input type="hidden" name="status" value="In Progress">
                                                            <button type="submit" class="btn btn-sm btn-warning">Start</button>
                                                        <% } else if (task.status === 'In Progress') { %>
                                                            <input type="hidden" name="status" value="Done">
                                                            <button type="submit" class="btn btn-sm btn-success">Complete</button>
                                                        <% } else { %>
                                                            <span class="text-muted">Done</span>
                                                        <% } %>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center text-muted p-4">You have no tasks assigned in the active sprint.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="col-lg-4">
                <!-- Team Info Card -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-users me-2"></i>My Team: <%= team.name %></h6>
                    </div>
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <strong><%= team.guide.name %></strong>
                            <span class="badge bg-primary">Guide</span>
                        </div>
                        <% team.students.forEach(student => { %>
                            <div class="list-group-item"><%= student.name %></div>
                        <% }); %>
                    </div>
                </div>

                <!-- Past Sprints Card -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-history me-2"></i>Recent Sprints</h6>
                    </div>
                    <div class="list-group list-group-flush">
                        <% if (pastSprints && pastSprints.length > 0) { %>
                            <% pastSprints.forEach(sprint => { %>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <%= sprint.name %>
                                    <span class="badge bg-success"><%= sprint.completed %> SP</span>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="list-group-item text-muted">No completed sprints yet.</div>
                        <% } %>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/student/past-sprints">View All Past Sprints</a>
                    </div>
                </div>
            </div>
        </div>

    <% } else { %>
        <!-- Message for students not in a team -->
        <div class="card shadow text-center p-5">
            <div class="card-body">
                <h4 class="card-title">Welcome to Sprint Sync!</h4>
                <p class="card-text text-muted">You are not yet assigned to a team. Please wait for the administrator to assign you.</p>
            </div>
        </div>
    <% } %>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Active Sprint Burndown Chart
    <% if (activeSprint && burndownChartData) { %>
        new Chart(document.getElementById('sprintBurndownChart'), {
            type: 'line',
            data: {
                labels: <%- burndownChartData.labels %>,
                datasets: [
                    { label:'Remaining Work', data:<%- burndownChartData.actualData %>, borderColor:'#A29BFE', backgroundColor: 'rgba(162, 155, 254, 0.1)', fill:true, tension: 0.1 },
                    { label:'Ideal Pace', data:<%- burndownChartData.idealData %>, borderColor:'#ccc', borderDash:[5,5], fill:false, tension: 0.1 }
                ]
            },
            options:{ responsive:true, maintainAspectRatio:false, scales: { y: { beginAtZero: true, title: { display: true, text: 'Story Points' } } } }
        });
    <% } %>

    // Overall Project Burndown Chart
    <% if (team && team.overallBurndownChartData) { %>
        new Chart(document.getElementById('overallBurndownChart'), {
            type: 'line',
            data: {
                labels: <%- team.overallBurndownChartData.labels %>,
                datasets: [{
                    label: 'Actual Remaining Points',
                    data: <%- team.overallBurndownChartData.actualData %>,
                    borderColor: 'rgba(28, 200, 138, 1)',
                    backgroundColor: 'rgba(28, 200, 138, 0.1)',
                    fill: true,
                    tension: 0.1
                }, {
                    label: 'Ideal Burn',
                    data: <%- team.overallBurndownChartData.idealData %>,
                    borderColor: 'rgba(231, 74, 59, 1)',
                    borderDash: [5, 5],
                    fill: false,
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        title: { display: true, text: 'Story Points' }
                    }
                }
            }
        });
    <% } %>
});
</script>