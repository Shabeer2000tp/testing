<%- include('../partials/_messages') %>

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><%= title %></h1>
        <a href="/student/dashboard" class="btn btn-sm btn-outline-secondary shadow-sm"><i class="fas fa-arrow-left fa-sm me-2"></i>Back to Dashboard</a>
    </div>

    <% if (team) { %>
        <div class="row">
            <!-- Backlog Items Column -->
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Current Backlog Items</h6>
                    </div>
                    <div class="card-body">
                        <% if (backlogItems.length > 0) { %>
                            <div class="list-group">
                                <% backlogItems.forEach(item => { %>
                                    <% 
                                        let priorityClass = '';
                                        if (item.priority === 'High') priorityClass = 'border-danger';
                                        if (item.priority === 'Medium') priorityClass = 'border-warning';
                                        if (item.priority === 'Low') priorityClass = 'border-info';
                                    %>
                                    <div class="list-group-item backlog-item <%= priorityClass %> mb-3">
                                        <div class="d-flex w-100 justify-content-between">
                                            <p class="mb-1 flex-grow-1"><%= item.description %></p>
                                            <div class="d-flex flex-column align-items-end ms-3">
                                                <span class="badge 
                                                    <% if (item.priority === 'High') { %>bg-danger<% } %>
                                                    <% if (item.priority === 'Medium') { %>bg-warning text-dark<% } %>
                                                    <% if (item.priority === 'Low') { %>bg-info text-dark<% } %>
                                                "><%= item.priority %></span>
                                                <small class="text-muted mt-1"><%= new Date(item.createdAt).toLocaleDateString() %></small>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <% if (item.status === 'New') { %>
                                                <span class="badge bg-primary">Status: <%= item.status %></span>
                                                <a href="/student/backlog/<%= item._id %>/plan" class="btn btn-sm btn-success">
                                                    <i class="fas fa-plus-circle me-1"></i> Plan Task
                                                </a>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Status: <%= item.status %></span>
                                                <span class="text-muted fst-italic">Task planned</span>
                                            <% } %>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center p-5">
                                <p class="text-muted">Your project backlog is empty. Add some items to get started!</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Add New Item Column -->
            <div class="col-lg-4">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Add New Backlog Item</h6>
                    </div>
                    <div class="card-body">
                        <form action="/student/backlog" method="POST">
                            <input type="hidden" name="teamId" value="<%= team._id %>">
                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea class="form-control" id="description" name="description" rows="4" placeholder="As a [user type], I want to [do something] so that [I can achieve some goal]." required></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="priority" class="form-label">Priority</label>
                                <select class="form-select" id="priority" name="priority" required>
                                    <option value="1">High</option>
                                    <option value="2" selected>Medium</option>
                                    <option value="3">Low</option>
                                </select>
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary">Add to Backlog</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="card shadow text-center p-5">
            <div class="card-body">
                <h4 class="card-title">No Team Assigned</h4>
                <p class="card-text text-muted">You must be part of a team to manage a project backlog.</p>
            </div>
        </div>
    <% } %>
</div>

<style>
    .backlog-item {
        border-left: 5px solid #ccc;
        transition: box-shadow 0.2s ease-in-out;
    }
    .backlog-item:hover {
        box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15)!important;
    }
    .border-danger { border-left-color: #e74a3b !important; }
    .border-warning { border-left-color: #f6c23e !important; }
    .border-info { border-left-color: #36b9cc !important; }
</style>