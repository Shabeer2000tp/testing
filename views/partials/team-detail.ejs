<!-- Page Header with Actions -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="welcome-header h3 mb-0"><%= team.name %></h1>
        <p class="text-muted mb-0">Project: <%= team.projectTitle || 'Not yet defined' %> (<%= team.domainName %>)</p>
    </div>
    <div class="d-flex gap-2">
        <% if (user.role === 'admin') { %>
            <a href="/admin/teams/<%= team._id %>/edit" class="btn btn-outline-secondary"><i class="fas fa-edit me-2"></i>Edit Team</a>
            <a href="/admin/teams/<%= team._id %>/backlog" class="btn btn-outline-secondary"><i class="fas fa-list-ul me-2"></i>View Backlog</a>
            <a href="/admin/teams/<%= team._id %>/report" class="btn btn-primary"><i class="fas fa-file-alt me-2"></i>Generate Report</a>
        <% } else if (user.role === 'guide') { %>
            <a href="/guide/teams/<%= team._id %>/backlog" class="btn btn-outline-secondary"><i class="fas fa-list-ul me-2"></i>View Backlog</a>
            <a href="/guide/dashboard" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
        <% } else { %>
            <a href="/student/dashboard" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
        <% } %>
    </div>
</div>

<%- include('../partials/_messages.ejs') %>

<!-- Stat Cards -->
<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card stat-card" style="border-left-color: var(--accent);">
            <div class="card-body">
                <div class="stat-card-title">Active Sprint</div>
                <div class="stat-card-value fs-5"><%= activeSprint ? activeSprint.name : 'None' %></div>
                <i class="fas fa-sync-alt stat-card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card stat-card" style="border-left-color: #28a745;">
            <div class="card-body">
                <div class="stat-card-title">Sprint Progress</div>
                <div class="stat-card-value"><%= activeSprint ? `${team.completedStoryPoints} / ${team.sprintCapacity}` : 'N/A' %> <span class="fs-6 text-muted">SP</span></div>
                <i class="fas fa-check-circle stat-card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card stat-card" style="border-left-color: #f6c23e;">
            <div class="card-body">
                <div class="stat-card-title">Overall Progress</div>
                <div class="stat-card-value"><%= team.overallCompletedPoints %> / <%= team.overallTotalPoints || 'N/A' %> <span class="fs-6 text-muted">SP</span></div>
                <i class="fas fa-tasks stat-card-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card stat-card" style="border-left-color: #1cc88a;">
            <div class="card-body">
                <div class="stat-card-title">Team Members</div>
                <div class="stat-card-value"><%= team.students.length %></div>
                <i class="fas fa-users stat-card-icon"></i>
            </div>
        </div>
    </div>
</div>

<!-- Project Abstract Card (Collapsible) -->
<div class="card shadow mb-4">
    <a href="#projectAbstractCollapse" class="card-header py-3 d-block text-decoration-none" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="projectAbstractCollapse">
        <h6 class="m-0 font-weight-bold text-primary d-flex justify-content-between align-items-center">
            <span><i class="fas fa-book-open me-2"></i>Project Abstract</span>
            <i class="fas fa-chevron-down collapse-icon"></i>
        </h6>
    </a>
    <div class="collapse" id="projectAbstractCollapse">
        <div class="card-body">
            <p class="text-muted mb-0"><%= team.abstract %></p>
        </div>
    </div>
</div>

<% if (activeSprint) { %>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-info-circle me-2"></i>Active Sprint Details</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <strong>Sprint Name:</strong> <%= activeSprint.name %><br>
                    <strong>Goal:</strong> <%= activeSprint.goal %><br>
                </div>
                <div class="col-md-6">
                    <strong>Start Date:</strong> <%= new Date(activeSprint.startDate).toLocaleDateString() %><br>
                    <strong>End Date:</strong> <%= new Date(activeSprint.endDate).toLocaleDateString() %><br>
                    <strong>Capacity:</strong> <%= activeSprint.capacity %> Story Points
                </div>
            </div>
        </div>
    </div>
<% } %>


<% if (activeSprint) { %>
<div class="row">

    <!-- Left Column -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-line me-2"></i> Sprint Burndown Chart</h6>
            </div>
            <div class="card-body">
                <% if (team.burndownChartData) { %>
                    <div style="height: 300px;">
                        <canvas id="burndownChart"></canvas>
                    </div>
                <% } else { %>
                    <p class="text-center text-muted p-4">Not enough data to display burndown chart.</p>
                <% } %>
            </div>
        </div>

        <!-- Overall Project Burndown Chart -->
        <% if (team.overallBurndownChartData) { %>
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-chart-area me-2"></i>Overall Project Burndown</h6>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="overallBurndownChart"></canvas>
                    </div>
                </div>
            </div>
        <% } else if (!activeSprint) { %>
            
            <div class="card shadow mb-4">
                <div class="card-body text-center p-4"><p class="text-muted">No overall project data available to generate a burndown chart.</p></div>
            </div>
        <% } %>

    </div>

    <!-- Right Column -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs" id="teamDetailTabs" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tasks">Tasks</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#logs">Daily Logs</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#deliverables">Deliverables</button></li>
                </ul>
            </div>

            <div class="card-body p-0">
                <div class="tab-content">

                    <!-- Tasks -->
                    <div class="tab-pane fade show active" id="tasks">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 35%;">Task</th>
                                        <th>Assigned To</th>
                                        <th>Start Date</th>
                                        <th>End Date</th>
                                        <th>Status</th>
                                        <th>Points</th>
                                    </tr>
                                </thead>
                                <tbody>
                                <% if (team.tasks && team.tasks.length > 0) { %>
                                    <% team.tasks.forEach(task => { %>
                                        <tr>
                                            <td><%= task.description %></td>
                                            <td><%= task.assignedToAll ? 'All Members' : (task.assignedTo ? task.assignedTo.name.split(' ')[0] : 'Unassigned') %></td>
                                            <td><%= new Date(task.startDate).toLocaleDateString() %></td>
                                            <td><%= new Date(task.endDate).toLocaleDateString() %></td>
                                            <td><span class="status-badge <%= task.realtimeStatus.badgeClass %>"><%= task.realtimeStatus.text %></span></td>
                                            <td><span class="badge bg-secondary"><%= task.storyPoints %> SP</span></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="text-center text-muted p-4">No tasks in this sprint.</td></tr>
                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Logs -->
                    <div class="tab-pane fade" id="logs" style="max-height:450px; overflow-y:auto;">
                        <div class="list-group list-group-flush">
                        <% if (dailyLogs && dailyLogs.length > 0) { %>
                            <% dailyLogs.forEach(log => { %>
                                <div class="list-group-item">
                                    <p class="mb-1"><%= log.logContent %></p>
                                    <small class="text-muted d-block"><%= log.student.name %> on <%= new Date(log.createdAt).toLocaleDateString() %></small>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="text-center text-muted p-4">No daily logs.</div>
                        <% } %>
                        </div>
                    </div>

                    <!-- Deliverables -->
                    <div class="tab-pane fade" id="deliverables">
                        <div class="list-group list-group-flush">
                        <% if (deliverables && deliverables.length > 0) { %>
                            <% deliverables.forEach(file => { %>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <a href="/deliverables/download/<%= file._id %>" class="fw-bold"><i class="fas fa-file-alt me-2"></i><%= file.fileName %></a>
                                        <small class="d-block text-muted">Uploaded by: <%= file.uploadedBy.name %></small>
                                    </div>
                                    <a href="/deliverables/download/<%= file._id %>" class="btn btn-sm btn-outline-secondary"><i class="fas fa-download"></i></a>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="text-center text-muted p-4">No deliverables uploaded.</div>
                        <% } %>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Team Members Card -->
        <div class="card shadow mt-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-users me-2"></i> Team Members</h6>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <strong><%= team.guide.name %></strong>
                    <span class="badge bg-primary">Guide</span>
                </div>
                <% team.students.forEach(student => { %>
                    <div class="list-group-item"><%= student.name %></div>
                <% }); %>
            </div>
        </div>

        <!-- Upcoming Reviews Card -->
        <div class="card shadow mt-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-calendar-check me-2"></i> Upcoming Reviews</h6>
            </div>
            <div class="list-group list-group-flush">
                <% if (upcomingReviews && upcomingReviews.length > 0) { %>
                    <% upcomingReviews.forEach(review => { %>
                        <div class="list-group-item"><strong><%= new Date(review.reviewDate).toLocaleDateString() %></strong></div>
                    <% }); %>
                <% } else { %>
                    <div class="list-group-item text-muted">No upcoming reviews scheduled.</div>
                <% } %>
            </div>
        </div>
    </div>

</div>

<% } else { %>
<div class="card text-center p-5"><h4>No Active Sprint</h4><p class="text-muted">This team does not have an active sprint.</p></div>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function() {
<% if (activeSprint && team.burndownChartData) { %>
    new Chart(document.getElementById('burndownChart'), {
        type: 'line',
        data: {
            labels: <%- team.burndownChartData.labels %>,
            datasets: [
                { label:'Remaining Work', data:<%- team.burndownChartData.actualData %>, borderColor:'#A29BFE', fill:true },
                { label:'Ideal Pace', data:<%- team.burndownChartData.idealData %>, borderColor:'#ccc', borderDash:[5,5], fill:false }
            ]
        },
        options:{
            responsive:true,
            maintainAspectRatio:false,
            scales: {
                y: { beginAtZero: true, title: { display: true, text: 'Story Points' } }
            }
        }
    });
<% } %>
<% if (team.overallBurndownChartData) { %>
    new Chart(document.getElementById('overallBurndownChart'), {
        type: 'line',
        data: {
            labels: <%- team.overallBurndownChartData.labels %>,
            datasets: [{
                label: 'Actual Remaining Points',
                data: <%- team.overallBurndownChartData.actualData %>,
                borderColor: 'rgba(28, 200, 138, 1)', // Success color
                backgroundColor: 'rgba(28, 200, 138, 0.1)',
                fill: true,
                tension: 0.1
            }, {
                label: 'Ideal Burn',
                data: <%- team.overallBurndownChartData.idealData %>,
                borderColor: 'rgba(231, 74, 59, 1)', // Danger color
                borderDash: [5, 5],
                fill: false,
                tension: 0.1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    title: { display: true, text: 'Story Points' }
                }
            }
        }
    });
<% } %>
});
</script>
